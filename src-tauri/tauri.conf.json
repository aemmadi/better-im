{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Better iMessage",
  "version": "0.1.0",
  "identifier": "com.aemmadi.better-im",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Better iMessage",
        "width": 1140,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/Library/Messages/Attachments/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "public.app-category.social-networking",
    "copyright": "Copyright © 2026 Anirudh Emmadi. Licensed under the GNU GPL-3.0-or-later.",
    "shortDescription": "Read and search your local iMessage history",
    "longDescription": "Better iMessage is a native macOS reader and search app for the local Messages database. It reads your conversations, ranks keyword and semantic (on-device) search, and surfaces galleries, shared links, insights, and a unified timeline — all on-device. Nothing ever leaves your Mac.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 180 },
        "applicationFolderPosition": { "x": 480, "y": 180 }
      }
    }
  }
}
