{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Better iMessage",
  "version": "0.1.0",
  "identifier": "com.aemmadi.better-im",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Better iMessage",
        "width": 1140,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "SocialNetworking",
    "shortDescription": "Read and search your local iMessage history",
    "longDescription": "Better iMessage is a native macOS reader and full-text search app for the local Messages database. All processing happens on-device; nothing leaves the machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
